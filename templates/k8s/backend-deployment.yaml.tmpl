apiVersion: apps/v1
kind: Deployment
metadata:
  name: backend
  namespace: {{ .k8sNamespace }}
spec:
  replicas: {{ .backendReplicas }}
  selector:
    matchLabels:
      app: backend
  template:
    metadata:
      labels:
        app: backend
    spec:
      containers:
        - name: backend
          image: backend:latest
          imagePullPolicy: IfNotPresent
          ports:
            - containerPort: {{ .appPort }}
          env:
            - name: API_PREFIX
              value: {{ .apiPrefix }}
            - name: PORT
              value: "{{ .appPort }}"
